# EC2
resource "aws_instance" "db" {
  ami                    = var.ami_id
  instance_type          = var.instance_type
  subnet_id              = var.subnet_id
  vpc_security_group_ids = [var.sg_postgres_id]
  key_name               = var.key_name
  associate_public_ip_address = false

  root_block_device {
    volume_size = var.volume_size
    volume_type = var.volume_type
    iops        = var.volume_iops
  }

  user_data = <<-EOF
    #!/bin/bash
    set -e
    sudo apt update
    sudo apt install -y postgresql postgresql-contrib
    sudo systemctl start postgresql
    sudo systemctl enable postgresql
    PG_CONF="/etc/postgresql/16/main/postgresql.conf"
    PG_HBA="/etc/postgresql/16/main/pg_hba.conf"
    sudo sed -i "s/#listen_addresses = 'localhost'/listen_addresses = '*'/" $PG_CONF
    echo "host all all 0.0.0.0/0 md5" | sudo tee -a $PG_HBA
    sudo ufw allow 5432/tcp
    sudo systemctl restart postgresql
    sudo -u postgres psql -c "CREATE DATABASE order_platform;"
    sudo -u postgres psql -c "CREATE USER bonun WITH PASSWORD 'password';"
    sudo -u postgres psql -c "GRANT ALL PRIVILEGES ON DATABASE order_platform TO bonun;"
    sudo -u postgres psql -d order_platform <<'EOF'
    CREATE TABLE PUBLIC.BATCH_JOB_INSTANCE(JOB_INSTANCE_ID BIGINT NOT NULL PRIMARY KEY,VERSION BIGINT,JOB_NAME VARCHAR(100) NOT NULL,JOB_KEY VARCHAR(32) NOT NULL,CONSTRAINT JOB_INST_UN UNIQUE (JOB_NAME, JOB_KEY));
    CREATE TABLE PUBLIC.BATCH_JOB_EXECUTION(JOB_EXECUTION_ID BIGINT NOT NULL PRIMARY KEY,VERSION BIGINT,JOB_INSTANCE_ID BIGINT NOT NULL CONSTRAINT JOB_INST_EXEC_FK REFERENCES PUBLIC.BATCH_JOB_INSTANCE,CREATE_TIME TIMESTAMP NOT NULL,START_TIME TIMESTAMP,END_TIME TIMESTAMP,STATUS VARCHAR(10),EXIT_CODE VARCHAR(2500),EXIT_MESSAGE VARCHAR(2500),LAST_UPDATED TIMESTAMP);
    CREATE TABLE PUBLIC.BATCH_JOB_EXECUTION_PARAMS(JOB_EXECUTION_ID BIGINT NOT NULL CONSTRAINT JOB_EXEC_PARAMS_FK REFERENCES PUBLIC.BATCH_JOB_EXECUTION,PARAMETER_NAME VARCHAR(100) NOT NULL,PARAMETER_TYPE VARCHAR(100) NOT NULL,PARAMETER_VALUE VARCHAR(2500),IDENTIFYING CHAR NOT NULL);
    CREATE TABLE PUBLIC.BATCH_STEP_EXECUTION(STEP_EXECUTION_ID BIGINT NOT NULL PRIMARY KEY,VERSION BIGINT NOT NULL,STEP_NAME VARCHAR(100) NOT NULL,JOB_EXECUTION_ID BIGINT NOT NULL CONSTRAINT JOB_EXEC_STEP_FK REFERENCES PUBLIC.BATCH_JOB_EXECUTION,CREATE_TIME TIMESTAMP NOT NULL,START_TIME TIMESTAMP,END_TIME TIMESTAMP,STATUS VARCHAR(10),COMMIT_COUNT BIGINT,READ_COUNT BIGINT,FILTER_COUNT BIGINT,WRITE_COUNT BIGINT,READ_SKIP_COUNT BIGINT,WRITE_SKIP_COUNT BIGINT,PROCESS_SKIP_COUNT BIGINT,ROLLBACK_COUNT BIGINT,EXIT_CODE VARCHAR(2500),EXIT_MESSAGE VARCHAR(2500),LAST_UPDATED TIMESTAMP);
    CREATE TABLE PUBLIC.BATCH_STEP_EXECUTION_CONTEXT(STEP_EXECUTION_ID BIGINT NOT NULL PRIMARY KEY CONSTRAINT STEP_EXEC_CTX_FK REFERENCES PUBLIC.BATCH_STEP_EXECUTION,SHORT_CONTEXT VARCHAR(2500) NOT NULL,SERIALIZED_CONTEXT TEXT);
    CREATE TABLE PUBLIC.BATCH_JOB_EXECUTION_CONTEXT(JOB_EXECUTION_ID BIGINT NOT NULL PRIMARY KEY CONSTRAINT JOB_EXEC_CTX_FK REFERENCES PUBLIC.BATCH_JOB_EXECUTION,SHORT_CONTEXT VARCHAR(2500) NOT NULL,SERIALIZED_CONTEXT TEXT);
    CREATE TABLE P_USER(CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,USER_ID BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,PHONE_NUMBER VARCHAR(20) NOT NULL UNIQUE,USER_ROLE VARCHAR(20) NOT NULL CHECK (USER_ROLE IN ('CUSTOMER','OWNER','MANAGER','MASTER')),NICKNAME VARCHAR(50) NOT NULL UNIQUE,REAL_NAME VARCHAR(50) NOT NULL,USERNAME VARCHAR(50) NOT NULL UNIQUE,EMAIL VARCHAR(100) NOT NULL UNIQUE,PASSWORD VARCHAR(255) NOT NULL);
    CREATE TABLE P_CATEGORY(CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,CATEGORY_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),CATEGORY_NAME VARCHAR(100) NOT NULL);
    CREATE TABLE P_REGION(IS_ACTIVE BOOLEAN NOT NULL,CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,REGION_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),SIDO VARCHAR(20),EUPMYENDONG VARCHAR(30),SIGUNGU VARCHAR(30),REGION_NAME VARCHAR(100) NOT NULL,FULL_NAME VARCHAR(255) NOT NULL,REGION_CODE VARCHAR(255) NOT NULL UNIQUE);
    CREATE TABLE P_STORE(CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,MIN_ORDER_AMOUNT BIGINT NOT NULL,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,USER_ID BIGINT NOT NULL REFERENCES P_USER(USER_ID),CATEGORY_ID UUID NOT NULL REFERENCES P_CATEGORY(CATEGORY_ID),REGION_ID UUID NOT NULL REFERENCES P_REGION(REGION_ID),STORE_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),PHONE_NUMBER VARCHAR(20),STORE_NAME VARCHAR(100) NOT NULL,ADDRESS VARCHAR(255) NOT NULL,DESCRIPTION VARCHAR(255),STORE_ACCEPT_STATUS VARCHAR(255) NOT NULL CHECK (STORE_ACCEPT_STATUS IN ('PENDING','APPROVE','REJECT')));
    CREATE TABLE P_CART(CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,USER_ID BIGINT NOT NULL UNIQUE REFERENCES P_USER(USER_ID),CART_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4());
    CREATE TABLE P_USER_ADDRESS(IS_DEFAULT BOOLEAN NOT NULL,CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,USER_ID BIGINT NOT NULL REFERENCES P_USER(USER_ID),ADDRESS_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),ALIAS VARCHAR(50) NOT NULL,ADDRESS VARCHAR(255) NOT NULL,ADDRESS_DETAIL VARCHAR(255) NOT NULL);
    CREATE TABLE P_REFRESH_TOKEN(CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,EXPIRATION BIGINT NOT NULL,ID BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,USER_ID BIGINT NOT NULL UNIQUE REFERENCES P_USER(USER_ID),TOKEN TEXT NOT NULL);
    CREATE TABLE P_MENU(IS_HIDDEN BOOLEAN NOT NULL,CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,PRICE BIGINT NOT NULL,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,CATEGORY_ID UUID NOT NULL REFERENCES P_CATEGORY(CATEGORY_ID),MENU_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),STORE_ID UUID NOT NULL REFERENCES P_STORE(STORE_ID),NAME VARCHAR(100) NOT NULL,DESCRIPTION VARCHAR(255));
    CREATE TABLE P_ORDERS(IS_REFUNDABLE BOOLEAN NOT NULL,CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,TOTAL_PRICE BIGINT NOT NULL,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,USER_ID BIGINT REFERENCES P_USER(USER_ID),ORDERS_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),STORE_ID UUID NOT NULL REFERENCES P_STORE(STORE_ID),ORDER_CHANNEL VARCHAR(20) NOT NULL CHECK (ORDER_CHANNEL IN ('OFFLINE','ONLINE')),ORDER_STATUS VARCHAR(20) NOT NULL CHECK (ORDER_STATUS IN ('PENDING','ACCEPTED','COOKING','IN_DELIVERY','COMPLETED','REJECTED','REFUNDED','FAILED')),RECEIPT_METHOD VARCHAR(20) NOT NULL CHECK (RECEIPT_METHOD IN ('DELIVERY','TAKE_OUT','TAKE_IN')),PAYMENT_METHOD VARCHAR(50) NOT NULL CHECK (PAYMENT_METHOD IN ('CREDIT_CARD','SIMPLE_PAY','BANK_TRANSFER','CASH')),DELIVERY_ADDRESS VARCHAR(255) NOT NULL,ORDER_HISTORY TEXT NOT NULL,REQUEST_MESSAGE VARCHAR(255));
    CREATE TABLE P_B_ORDER_ITEM(QUANTITY INTEGER NOT NULL,CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,PRICE BIGINT NOT NULL,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,ORDER_ITEM_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),ORDERS_ID UUID NOT NULL REFERENCES P_ORDERS(ORDERS_ID),MENU_NAME VARCHAR(100) NOT NULL);
    CREATE TABLE P_REVIEW(CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,RATING BIGINT NOT NULL,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,USER_ID BIGINT NOT NULL REFERENCES P_USER(USER_ID),B_ORDER_ID UUID NOT NULL UNIQUE REFERENCES P_ORDERS(ORDERS_ID),REVIEW_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),STORE_ID UUID NOT NULL REFERENCES P_STORE(STORE_ID),CONTENT VARCHAR(255) NOT NULL,STORE_NAME VARCHAR(255),USER_NAME VARCHAR(255));
    CREATE TABLE P_PAYMENT(PAYMENT_METHOD SMALLINT NOT NULL CHECK (PAYMENT_METHOD >= 0 AND PAYMENT_METHOD <= 3),AMOUNT BIGINT NOT NULL,CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,ORDERS_ID UUID NOT NULL UNIQUE,PAYMENT_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),PAYMENT_KEY VARCHAR(255) NOT NULL,PAYMENT_STATUS VARCHAR(255) NOT NULL CHECK (PAYMENT_STATUS IN ('COMPLETED','FAILED','CANCELLED')));
    CREATE TABLE P_PAYMENT_ETC(CREATED_AT TIMESTAMP(6) NOT NULL,CREATED_BY BIGINT,DELETED_AT TIMESTAMP(6),DELETED_BY BIGINT,UPDATED_AT TIMESTAMP(6) NOT NULL,UPDATED_BY BIGINT,PAYMENT_ETC_ID UUID NOT NULL PRIMARY KEY DEFAULT uuid_generate_v4(),PAYMENT_ID UUID NOT NULL REFERENCES P_PAYMENT(PAYMENT_ID),PAYMENT_RESPONSE TEXT NOT NULL);
    CREATE TABLE AI_HISTORY(ID BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,USER_ID BIGINT NOT NULL,MESSAGE TEXT NOT NULL,ROLE VARCHAR(50) NOT NULL,CREATED_AT TIMESTAMP(6) NOT NULL DEFAULT NOW());
    EOF


  tags = merge(var.tags, {
    Name = "${var.name}-postgres"
  })
}